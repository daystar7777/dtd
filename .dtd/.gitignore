# DTD — local-only artifacts. Do not commit.

# Secrets
.env
.env.local
.env.*.local

# Local-only user config (committed example: workers.example.md)
# Your actual worker registry stays local — endpoints, model choices, aliases
# don't leak when project is pushed to git.
workers.md

# Runtime scratch + per-run history
tmp/
log/
eval/
attempts/
runs/

# Backups from /dtd uninstall
../.dtd.uninstalled-*/

# Stale lock dropfile (if used by tools)
.rotation.lock
.dtd.lock

# Editor / OS noise within .dtd/
.DS_Store
Thumbs.db
*.swp
*.swo

# DTD — local-only artifacts. Do not commit.

# Secrets
.env
.env.local
.env.*.local

# Local-only user config (committed example: workers.example.md)
# Your actual worker registry stays local — endpoints, model choices, aliases
# don't leak when project is pushed to git.
# Root-anchored so .dtd/help/workers.md (v0.2.0d help topic file) is NOT ignored.
/workers.md

# Runtime scratch + per-run history
tmp/
log/
eval/
attempts/
runs/

# v0.2.0b permission audit log (gitignored under log/) — explicit for clarity
log/permissions.md

# v0.2.0c snapshots — local pre-apply file content. Never committed.
# index.md template is tracked; per-apply snap-*/ dirs and archived/ are not.
snapshots/snap-*/
snapshots/archived/

# v0.3.0a cross-run loop guard ledger — local stable signatures. Never
# committed. Lazy-created at first finalize_run capture-before-clear.
cross-run-loop-guard.md

# Backups from /dtd uninstall
../.dtd.uninstalled-*/

# Stale lock dropfile (if used by tools)
.rotation.lock
.dtd.lock

# Editor / OS noise within .dtd/
.DS_Store
Thumbs.db
*.swp
*.swo

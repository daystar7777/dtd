# DTD — example env file. Copy to .env and fill in real keys.
# .env is gitignored. Keys are referenced by NAME in workers.md (api_key_env field),
# never by value. The controller resolves env vars at HTTP header time only.

# Local Ollama (no key needed but field required by some clients)
OLLAMA_API_KEY=ollama

# Local vLLM / LM Studio
VLLM_API_KEY=local

# Remote Qwen on private endpoint
QWEN_API_KEY=

# OpenAI / Codex
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# DeepSeek hosted
DEEPSEEK_API_KEY=

# OpenRouter (multi-provider gateway)
OPENROUTER_API_KEY=

# Hugging Face Inference
HF_API_KEY=

# Generic / custom worker
CUSTOM_WORKER_API_KEY=
